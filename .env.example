# Tripo image-to-3D API. Server-side only.
TRIPO_API_KEY=

# OpenAI image generation API. Server-side only.
# Used to render the drawing as a single 3/4 volumetric "toy" image before Tripo builds the model.
OPENAI_API_KEY=

# Image model used for the doodle -> 3/4 3D render (image-to-image).
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=2048x2048
OPENAI_IMAGE_QUALITY=medium

# Optional. Leave blank to use Tripo's current default image-to-model version.
TRIPO_MODEL_VERSION=

# Fidelity-first defaults. Higher texture quality costs more credits.
# standard | detailed | extreme
TRIPO_TEXTURE_QUALITY=standard

# original_image prioritizes visual similarity to the drawing over geometric consistency.
# original_image | geometry
TRIPO_TEXTURE_ALIGNMENT=original_image

# Keep false when you want the output to preserve the drawing's exact style.
TRIPO_ENABLE_IMAGE_AUTOFIX=false

# Keep false for flatter, drawing-like materials; set true for PBR/realistic material output.
TRIPO_PBR=false

# Optional. Cap on mesh face count; lower = simpler, blockier (more doodle-like) geometry.
# Leave blank to use Tripo's default density.
TRIPO_FACE_LIMIT=

# Optional. Leave blank for local dev; the status route can poll Tripo instead.
# Use this only when Tripo can reach your machine through a tunnel or public URL.
TRIPO_WEBHOOK_URL=

# Optional. Required only when enabling webhook verification.
TRIPO_WEBHOOK_SECRET=

# Local-only storage/database paths. These default to .data/* if unset.
LOCAL_DATA_DIR=.data
LOCAL_STORAGE_DIR=.data/storage
